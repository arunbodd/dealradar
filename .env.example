# ── Required ──────────────────────────────────────────────────
# auto.dev API key — powers the car inventory search
# Get yours at https://auto.dev
AUTO_DEV_API_KEY=your_autodev_api_key_here

# Anthropic Claude API key — required for all AI features
# (natural language search, deal analysis, market pulse, concierge QA)
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Optional ──────────────────────────────────────────────────
# Override the SQLite database path (defaults to ~/.car-deal-finder/inventory.db)
# On Render/cloud: set to /tmp/inventory.db
# DB_PATH=/tmp/inventory.db
